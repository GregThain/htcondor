
COLLECTOR_HOST = flock.opensciencegrid.org

# Add SSL AUTH
SEC_DAEMON_AUTHENTICATION_METHODS = $(SEC_DAEMON_AUTHENTICATION_METHODS), SSL

# probably need this for container mode
SSL_SKIP_HOST_CHECK = true

# Define the map file
CERTIFICATE_MAPFILE = /etc/condor/certificate_mapfile

# Host/client certs and keys
AUTH_SSL_SERVER_CERTFILE = /etc/condor/certs-orig.d/hostcert
AUTH_SSL_CLIENT_CERTFILE = /etc/condor/certs-orig.d/hostcert
AUTH_SSL_SERVER_KEYFILE  = /etc/condor/certs-orig.d/hostkey
AUTH_SSL_CLIENT_KEYFILE  = /etc/condor/certs-orig.d/hostkey

# and the ca cert -- real OSG machine mount these via cvmfs
AUTH_SSL_SERVER_CAFILE = InCommon-IGTF-Server-CA.pem
AUTH_SSL_CLIENT_CAFILE = InCommon-IGTF-Server-CA.pem


# Allow SSL auth'd access to this daemon
ALLOW_DAEMON = $(ALLOW_DAEMON) condor@*/*

# We live behind a NAT most likely -- use CCB to allow incoming requests.
CCB_ADDRESS = flock.opensciencegrid.org

SEC_DEFAULT_AUTHENTICATION_METHODS = TOKEN, $(SEC_DEFAULT_AUTHENTICATION_METHODS)
SEC_CLIENT_AUTHENTICATION_METHODS = $(SEC_DEFAULT_AUTHENTICATION_METHODS)

# Uncomment this line to disable the actual negotiation.
NEGOTIATOR_SLOT_CONSTRAINT = (GLIDEIN_Site == "Nebraska")

# Due to a condor eccentricity a negotiator must have a '@' or a '.' in the name;
# using NEGOTIATOR_NAME triggers the '@' to be present.
NEGOTIATOR_NAME = k8s

# Allow issued tokens to set priorities of users.
ALLOW_ADMINISTRATOR = $(ALLOW_ADMINISTRATOR) osg-admin@flock.opensciencegrid.org

# We can't volume mount the password file in the default place, so put it here
SEC_PASSWORD_FILE = /etc/condor/passwords-orig.d/osg-flock-negotiator
